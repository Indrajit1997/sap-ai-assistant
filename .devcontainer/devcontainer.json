{
  "name": "SAP AI Assistant",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {},
  "forwardPorts": [8000, 8501],
  "portsAttributes": {
    "8000": { "label": "Backend API", "onAutoForward": "silent" },
    "8501": { "label": "Streamlit UI", "onAutoForward": "notify" }
  },
  "postCreateCommand": "pip install -r backend/requirements.txt && pip install streamlit==1.39.0",
  "postStartCommand": "bash scripts/start_codespace.sh",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
